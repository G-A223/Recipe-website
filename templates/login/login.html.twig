{% extends "base.html.twig" %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/auth_form.css') }}">
{% endblock %}

{% block body %}
    {% if error %}
        <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form class="auth-form" action="{{ path('login') }}" method="post">
        <h2>Вход</h2>

        <input type="email" id="email" name="_email" placeholder="Почта"  value="{{ last_username }}" required>
        <input type="password" id="password" name="_password" placeholder="Пароль" required>

        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="auth-form-btn">Войти</button>

        {# <p><a href="#">Забыли пароль?</a></p> #}
        <p>Нет аккаунта? <a href="{{ path('registration') }}">Зарегистрироваться</a></p>
    </form>
{% endblock %}
