{% extends "base.html.twig" %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/auth_form.css') }}">
{% endblock %}

{% block body %}
    <form class="auth-form" action="{{ path('registration') }}" method="post" name="register_form">
        <h2>Регистрация</h2>

        <input type="text" id="username" name="_username" placeholder="Логин" required>
        <input type="email" id="email" name="_email" placeholder="Почта" required>
        <input type="password" id="password" name="_password" placeholder="Пароль" required>
        <input type="password" id="password_repeat" name="_password_repeat" placeholder="Повторите пароль" required>

        <button type="submit" class="auth-form-btn">Зарегистрироваться</button>

        <p>Уже есть аккаунт? <a href="{{ path('login') }}">Войти</a></p>
    </form>
{% endblock %}
