{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/recipe.css') }}">
{% endblock %}

{% block body %}
    <div class="article-container">
        <h1>{{ recipe.title }}</h1>

        {% if recipe.image %}
            <img class="article-img" src="{{ asset('images/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}">
        {% endif %}

        <p class="description">{{ recipe.description }}</p>

        <div class="recipe-tags-categories">
            {% if recipe.tags|length > 0 %}
                <div class="tags">
                    <strong>Теги:</strong>
                    {% for tag in recipe.tags %}
                        <span class="tag">{{ tag.name }}</span>
                    {% endfor %}
                </div>
            {% endif %}

            {% if recipe.categories|length > 0 %}
                <div class="categories">
                    <strong>Категории:</strong>
                    {% for category in recipe.categories %}
                        <span class="category">{{ category.name }}</span>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <h2>Продукты для рецепта</h2>

        <table class="ingridients">
            {% for ingredient in recipe.ingredients %}
                <tr>
                    <td class="ingridient">{{ ingredient.name }}</td>
                    <td class="amount">{{ ingredient.amount }}</td>
                </tr>
            {% endfor %}
        </table>

        <div class="recipe">
            <h2>Пошаговый рецепт</h2>
            {% for step in recipe.steps %}
                <div class="recipe-step">
                    <span class="step-badge">Шаг {{ step.stepNumber }}</span>
                    {% if step.image %}
                        <img class="step-img" src="{{ asset('images/steps/' ~ step.image) }}" alt="Шаг {{ step.stepNumber }}">
                    {% endif %}
                    <p>{{ step.description }}</p>
                </div>
            {% endfor %}
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="edit-recipe">
                <button class="recipe-btn">Редактировать рецепт</button>
                <button class="recipe-btn" onclick="deleteRecipe({{ recipe.id }})">Удалить рецепт</button>
            </div>
        {% endif %}

        <div class="comment-section">
            <h2>Комментарии</h2>

            {% for message in app.flashes('error') %}
                <div class="flash-error">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('success') %}
                <div class="flash-success">{{ message }}</div>
            {% endfor %}

            {% if app.user %}
                <form class="post-comment" action="{{ path('comment_add', {'recipeId': recipe.id}) }}" method="POST">
                    <div class="user-comment-info">
                        <img class="user-comment-avatar" src="{{ asset('images/avatar.jpg') }}" alt="Аватар">
                        {{ app.user.login }}
                    </div>

                    <textarea class="comment-field" name="content" placeholder="Напишите комментарий..." required></textarea>

                    <div class="comment-actions">
                        <button type="submit" class="comment-btn">Оставить комментарий</button>
                    </div>
                </form>
            {% else %}
                <p>Войдите или зарегистрируйтесь, чтобы оставить комментарий</p>
            {% endif %}

            {% if recipe.comments|length > 0 %}
                <div class="comments-list">
                    {% for comment in recipe.comments|reverse %}
                        <div class="comment" id="comment-{{ comment.id }}">
                            <div class="comment-info">
                                <div class="comment-profile">
                                    <img class="comment-avatar" src="{{ asset('images/avatar.jpg') }}" alt="Аватар">
                                    <p class="comment-login">{{ comment.author.login }}</p>
                                </div>
                                <p class="comment-date">{{ comment.createdAt|date('d.m.Y H:i') }}</p>
                            </div>

                            <div class="comment-content" id="comment-content-{{ comment.id }}">
                                <p>{{ comment.content|nl2br }}</p>
                            </div>

                            <div class="edit-comment-form" id="edit-form-{{ comment.id }}" style="display: none;">
                                <form action="{{ path('comment_edit', {'id': comment.id}) }}" method="POST">
                                    <textarea class="comment-field" name="content" rows="3">{{ comment.content }}</textarea>
                                    <div class="edit-comment-actions">
                                        <button type="submit" class="comment-btn">Сохранить</button>
                                        <button type="button" class="cancel-btn" onclick="cancelEdit({{ comment.id }})">Отмена</button>
                                    </div>
                                </form>
                            </div>

                            {% if app.user and (app.user.id == comment.author.id or is_granted('ROLE_ADMIN')) %}
                                <div class="change-comment">
                                    <button class="change-comment-btn" onclick="editComment({{ comment.id }})">Редактировать</button>
                                    <button class="change-comment-btn" onclick="deleteComment({{ comment.id }})">Удалить</button>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>Будьте первым, кто оставит комментарий</p>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        function editComment(commentId) {
            const content = document.getElementById('comment-content-' + commentId);
            const editForm = document.getElementById('edit-form-' + commentId);

            content.style.display = 'none';
            editForm.style.display = 'block';
        }

        function cancelEdit(commentId) {
            const content = document.getElementById('comment-content-' + commentId);
            const editForm = document.getElementById('edit-form-' + commentId);

            content.style.display = 'block';
            editForm.style.display = 'none';
        }

        function deleteComment(commentId) {
            if (confirm('Вы уверены, что хотите удалить этот комментарий?')) {
                window.location.href = '{{ path('comment_delete', {'id': 'COMMENT_ID'}) }}'.replace('COMMENT_ID', commentId);
            }
        }
    </script>
{% endblock %}
