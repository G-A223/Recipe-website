{% extends "base.html.twig" %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/add_recipe.css') }}">
{% endblock %}

{% block body %}
    <div class="add-recipe-container">
        <h1>Создание нового рецепта</h1>

        <form class="add-recipe" method="POST" enctype="multipart/form-data">
            <div class="form-section">
                <h2>Основная информация</h2>

                <div class="form-group">
                    <label for="recipe-title">Название рецепта</label>
                    <input type="text" id="recipe-title" class="form-input" placeholder="Введите название рецепта" required>
                </div>

                <div class="form-group">
                    <label for="recipe-image">Главное изображение</label>
                    <input type="file" id="recipe-image" class="form-input" accept="image/*">
                    <div class="image-preview" id="main-image-preview"></div>
                </div>

                <div class="form-group">
                    <label for="recipe-description">Краткое описание</label>
                    <textarea id="recipe-description" class="form-input" placeholder="Опишите рецепт в нескольких предложениях..." rows="4"></textarea>
                </div>


                <div class="form-group">
                    <label>Теги рецепта</label>
                    <div class="tags-container" id="tags-container">
                        <div class="tag-item">
                            <input type="checkbox" id="tag-breakfast" value="breakfast">
                            <label for="tag-breakfast">Завтрак</label>
                        </div>
                        <div class="tag-item">
                            <input type="checkbox" id="tag-lunch" value="lunch">
                            <label for="tag-lunch">Обед</label>
                        </div>
                        <div class="tag-item">
                            <input type="checkbox" id="tag-dinner" value="dinner">
                            <label for="tag-dinner">Ужин</label>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Категории рецепта</label>
                    <div class="categories-container" id="categories-container">
                        <div class="category-item">
                            <input type="checkbox" id="cat-snacks" value="snacks">
                            <label for="cat-snacks">Закуски</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-salads" value="salads">
                            <label for="cat-salads">Салаты</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-soups" value="soups">
                            <label for="cat-soups">Первые блюда</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-main" value="main">
                            <label for="cat-main">Вторые блюда</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-garnishes" value="garnishes">
                            <label for="cat-garnishes">Гарниры</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-desserts" value="desserts">
                            <label for="cat-desserts">Десерты</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-bakery" value="bakery">
                            <label for="cat-bakery">Выпечка</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-drinks" value="drinks">
                            <label for="cat-drinks">Напитки</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-preserves" value="preserves">
                            <label for="cat-preserves">Заготовки</label>
                        </div>
                        <div class="category-item">
                            <input type="checkbox" id="cat-sauces" value="sauces">
                            <label for="cat-sauces">Соусы</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h2>Ингредиенты</h2>

                <div class="ingredients-list" id="ingredients-list">
                    <div class="ingredient-item">
                        <div class="form-group">
                            <label>Название ингредиента</label>
                            <input type="text" class="form-input ingredient-name" placeholder="Например: Мука">
                        </div>
                        <div class="form-group">
                            <label>Количество</label>
                            <input type="text" class="form-input ingredient-amount" placeholder="Например: 500 г">
                        </div>
                        <button type="button" class="remove-btn" onclick="removeIngredient(this)">✕</button>
                    </div>
                </div>

                <button type="button" class="add-btn" onclick="addIngredient()">
                    <span class="plus-icon">+</span> Добавить ингредиент
                </button>
            </div>

            <div class="form-section">
                <h2>Пошаговый рецепт</h2>

                <div class="steps-list" id="steps-list">
                    <div class="step-item">
                        <div class="step-header">
                            <span class="step-number">Шаг 1</span>
                        </div>
                        <div class="form-group">
                            <label>Изображение к шагу (необязательно)</label>
                            <input type="file" class="form-input step-image" accept="image/*">
                            <div class="image-preview step-image-preview"></div>
                        </div>
                        <div class="form-group">
                            <label>Описание шага</label>
                            <textarea class="form-input step-description" placeholder="Опишите, что нужно сделать на этом шаге..." rows="3"></textarea>
                        </div>
                        <button type="button" class="remove-btn" onclick="removeStep(this)">✕</button>
                    </div>
                </div>

                <button type="button" class="add-btn" onclick="addStep()">
                    <span class="plus-icon">+</span> Добавить шаг
                </button>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-btn">Сохранить рецепт</button>
                <button type="reset" class="reset-btn">Очистить всё</button>
            </div>
        </form>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        let ingredientCounter = 1;
        let stepCounter = 1;

        function addIngredient() {
            ingredientCounter++;
            const ingredientsList = document.getElementById('ingredients-list');

            const ingredientItem = document.createElement('div');
            ingredientItem.className = 'ingredient-item';
            ingredientItem.innerHTML = `
                <div class="form-group">
                    <label>Название ингредиента</label>
                    <input type="text" class="form-input ingredient-name" placeholder="Например: Мука">
                </div>
                <div class="form-group">
                    <label>Количество</label>
                    <input type="text" class="form-input ingredient-amount" placeholder="Например: 500 г">
                </div>
                <button type="button" class="remove-btn" onclick="removeIngredient(this)">✕</button>
            `;

            ingredientsList.appendChild(ingredientItem);
            updateIngredientsNumbers();
        }

        function removeIngredient(button) {
            const ingredientItem = button.parentElement;
            ingredientItem.remove();
            updateIngredientsNumbers();
        }

        function updateIngredientsNumbers() {
            const ingredients = document.querySelectorAll('.ingredient-item');
            ingredients.forEach((item, index) => {
            });
        }

        function addStep() {
            stepCounter++;
            const stepsList = document.getElementById('steps-list');

            const stepItem = document.createElement('div');
            stepItem.className = 'step-item';
            stepItem.innerHTML = `
                <div class="step-header">
                    <span class="step-number">Шаг ${stepCounter}</span>
                </div>
                <div class="form-group">
                    <label>Изображение к шагу (необязательно)</label>
                    <input type="file" class="form-input step-image" accept="image/*">
                    <div class="image-preview step-image-preview"></div>
                </div>
                <div class="form-group">
                    <label>Описание шага</label>
                    <textarea class="form-input step-description" placeholder="Опишите, что нужно сделать на этом шаге..." rows="3"></textarea>
                </div>
                <button type="button" class="remove-btn" onclick="removeStep(this)">✕</button>
            `;

            stepsList.appendChild(stepItem);
            updateStepNumbers();
        }

        function removeStep(button) {
            const stepItem = button.parentElement;
            stepItem.remove();
            updateStepNumbers();
        }

        function updateStepNumbers() {
            const steps = document.querySelectorAll('.step-item');
            steps.forEach((item, index) => {
                item.querySelector('.step-number').textContent = `Шаг ${index + 1}`;
            });
            stepCounter = steps.length;
        }

        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('step-image') || e.target.id === 'recipe-image') {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    const preview = e.target.nextElementSibling;

                    reader.onload = function(e) {
                        preview.innerHTML = `<img src="${e.target.result}" alt="Preview">`;
                        preview.style.display = 'block';
                    };

                    reader.readAsDataURL(file);
                }
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            updateStepNumbers();
        });
    </script>
{% endblock %}
